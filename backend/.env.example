# Backend environment variables for local development.
# Copy this file to `.env` and fill in real values.

# PostgreSQL connection string used by the application and by node-pg-migrate.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/leads_generator

# Redis connection string used for the session store and BullMQ work queues.
REDIS_URL=redis://localhost:6379/0

# RapidAPI Google Search Key (Subscribe to google-search74 by apigeek)
RAPIDAPI_KEY=

# Supabase Storage Configuration
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=content-assets

# Centralized AI key: team id whose team_ai_settings row holds the ONE shared
# AI API key used across the whole app. When set, admin configures the key once
# (via Settings) and every team/user uses it. Must be an existing team id.
# Leave blank for legacy per-team keys.
CENTRAL_AI_TEAM_ID=

# CORS allow-list. Comma-separated. The dev Chrome extension is always added.
# Format: scheme://host[:port]
CORS_ORIGIN=chrome-extension://hahcoepljmhmiaomolmfhbmpahnfbpep,http://localhost:3000
