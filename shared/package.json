{
  "name": "@leads-generator/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript domain types for Leads Generation Dashboard",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing/pbt": {
      "types": "./dist/testing/pbt.d.ts",
      "default": "./dist/testing/pbt.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "test": "vitest run --config vitest.config.ts"
  },
  "devDependencies": {
    "fast-check": "3.23.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
